---

## `.gitignore`

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter
.ipynb_checkpoints
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Project-specific runtime data
uploads/
outputs/
tmp/
chroma_db/
sample_pdf/
*.db
*.sqlite3

# Node/React (UI)
ui/node_modules/
ui/build/
ui/dist/
ui/.env.local
ui/.env.development.local
ui/.env.test.local
ui/.env.production.local
ui/npm-debug.log*
ui/yarn-debug.log*
ui/yarn-error.log*

# Model files (large binaries)
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx

# Docker
.dockerignore

# Misc temp files
*.bak
*.tmp
*.temp
